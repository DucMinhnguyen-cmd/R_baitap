col = "blue", pch = 16)
# 4. Loại bỏ các giá trị ngoại lai gây nhiễu
# Xóa những căn nhà có diện tích > 4000 nhưng giá < 300.000
d1 <- d1[!(d1$GrLivArea > 4000 & d1$SalePrice < 300000), ]
# 5. Kiểm tra lại kích thước dữ liệu (sẽ thấy hụt đi vài dòng so với 1460 ban đầu)
dim(d1)
colSums(is.na(d1))
# 1. Chuyển đổi các cột đánh giá chất lượng (Quality/Condition)
# Tạo hàm chuyển đổi chung
decode_quality <- function(x) {
x <- as.character(x)
x[x == "Ex"] <- "Excellent"
x[x == "Gd"] <- "Good"
x[x == "TA"] <- "Typical/Average"
x[x == "Fa"] <- "Fair"
x[x == "Po"] <- "Poor"
x[x == "None"] <- "No_Feature"
return(as.factor(x))
}
# Danh sách các cột áp dụng bảng mã này
qual_cols <- c("ExterQual", "ExterCond", "BsmtQual", "BsmtCond", "HeatingQC",
"KitchenQual", "FireplaceQu", "GarageQual", "GarageCond", "PoolQC")
d1[qual_cols] <- lapply(d1[qual_cols], decode_quality)
# 2. Chi tiết hóa cột BsmtExposure (Độ thoáng hầm)
d1$BsmtExposure <- as.character(d1$BsmtExposure)
d1$BsmtExposure[d1$BsmtExposure == "Gd"] <- "Good_Exposure"
d1$BsmtExposure[d1$BsmtExposure == "Av"] <- "Average_Exposure"
d1$BsmtExposure[d1$BsmtExposure == "Mn"] <- "Minimum_Exposure"
d1$BsmtExposure[d1$BsmtExposure == "No"] <- "No_Exposure"
d1$BsmtExposure[d1$BsmtExposure == "None"] <- "No_Basement"
d1$BsmtExposure <- as.factor(d1$BsmtExposure)
# 3. Chi tiết hóa cột GarageFinish (Độ hoàn thiện gara)
d1$GarageFinish <- as.character(d1$GarageFinish)
d1$GarageFinish[d1$GarageFinish == "Fin"] <- "Finished"
d1$GarageFinish[d1$GarageFinish == "RFn"] <- "Rough_Finished"
d1$GarageFinish[d1$GarageFinish == "Unf"] <- "Unfinished"
d1$GarageFinish[d1$GarageFinish == "None"] <- "No_Garage"
d1$GarageFinish <- as.factor(d1$GarageFinish)
# Tổng diện tích = Tầng 1 + Tầng 2 + Tầng hầm
d1$TotalSF <- d1$X1stFlrSF + d1$X2ndFlrSF + d1$TotalBsmtSF
# Diện tích hoàn thiện (không tính phần hầm thô)
d1$TotalFinishedSF <- d1$GrLivArea + d1$BsmtFinSF1 + d1$BsmtFinSF2
# Tuổi của căn nhà tại thời điểm bán
d1$HouseAge <- d1$YrSold - d1$YearBuilt
# Số năm kể từ lần cải tạo cuối cùng (nếu không cải tạo thì tính từ năm xây)
d1$YearsSinceRemodel <- d1$YrSold - d1$YearRemodAdd
# Biến đánh dấu: Nhà này có từng được cải tạo không? (1 là có, 0 là không)
d1$IsRemodeled <- ifelse(d1$YearBuilt == d1$YearRemodAdd, 0, 1)
# Tổng số phòng tắm
d1$TotalBath <- d1$FullBath + (0.5 * d1$HalfBath) +
d1$BsmtFullBath + (0.5 * d1$BsmtHalfBath)
# Có bể bơi không?
d1$HasPool <- ifelse(d1$PoolArea > 0, 1, 0)
# Có Garage không?
d1$HasGarage <- ifelse(d1$GarageArea > 0, 1, 0)
# Có lò sưởi không?
d1$HasFireplace <- ifelse(d1$Fireplaces > 0, 1, 0)
# Lấy các cột dạng số
numeric_cols <- sapply(d1, is.numeric)
cor_matrix <- cor(d1[, numeric_cols])
# Xem top 10 biến tương quan mạnh nhất với giá nhà
cor_with_price <- sort(cor_matrix[,"SalePrice"], decreasing = TRUE)
print("Top 10 biến ảnh hưởng mạnh nhất đến giá nhà:")
print(head(cor_with_price, 10))
# Vẽ biểu đồ tương quan (Yêu cầu cài library corrplot)
# install.packages("corrplot")
library(corrplot)
corrplot(cor_matrix, method = "circle", type = "upper", tl.col = "black", tl.cex = 0.6)
corrplot(cor_matrix, method = "circle", tl.col = "black", tl.cex = 0.6)
# Lấy tương quan của SalePrice với các biến khác
cor_values <- cor(d1[, sapply(d1, is.numeric)])["SalePrice", ]
cor_values <- sort(cor_values, decreasing = TRUE)
# Lấy top 10 (bỏ chính nó là SalePrice ở vị trí số 1)
top_10 <- cor_values[2:11]
# Vẽ biểu đồ cột nằm ngang
barplot(top_10, las = 2, col = "skyblue",
main = "Top 10 yếu tố ảnh hưởng mạnh nhất đến Giá Nhà",
xlab = "Hệ số tương quan", horiz = TRUE)
# Lấy top 10 (bỏ chính nó là SalePrice ở vị trí số 1)
top_10 <- cor_values[2:11]
# Vẽ biểu đồ cột nằm ngang
barplot(top_10, las = 2, col = "skyblue",
main = "Top 10 yếu tố ảnh hưởng mạnh nhất đến Giá Nhà",
xlab = "Hệ số tương quan", horiz = TRUE)
# So sánh chất lượng nhà bếp (KitchenQual) với Giá nhà
boxplot(SalePrice ~ KitchenQual, data = d1,
col = c("orange", "gold", "lightgreen", "lightblue"),
main = "Sự khác biệt Giá nhà theo Chất lượng Nhà bếp",
xlab = "Chất lượng nhà bếp", ylab = "Giá nhà (USD)")
# Vẽ diện tích tổng (biến mới tạo) vs Giá nhà
plot(d1$TotalSF, d1$SalePrice,
pch = 19, col = rgb(0.2, 0.4, 0.6, 0.5),
main = "Mối quan hệ giữa Tổng diện tích và Giá nhà",
xlab = "Tổng diện tích (TotalSF)", ylab = "Giá nhà")
# Thêm đường xu hướng (Regression line) màu đỏ
abline(lm(SalePrice ~ TotalSF, data = d1), col = "red", lwd = 2)
boxplot(SalePrice ~ KitchenQual, data = d1,
col = c("orange", "gold", "lightgreen", "lightblue"),
main = "Sự khác biệt Giá nhà theo Chất lượng Nhà bếp",
xlab = "Chất lượng nhà bếp", ylab = "Giá nhà (USD)")
